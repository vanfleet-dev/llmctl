show_ps() {
    echo -e "${BLUE}Running llama-server processes:${NC}"
    ps aux | grep "llama-server" | grep -v grep || echo "No llama-server processes running"
}

show_logs() {
    local model=${1:-}
    local follow=false
    
    # Check for -f flag
    for arg in "$@"; do
        if [[ "$arg" == "-f" ]]; then
            follow=true
        fi
    done
    
    if [[ -z "$model" || "$model" == "-f" ]]; then
        echo -e "${BLUE}Recent logs from all models:${NC}"
        echo ""
        for logfile in "${LOG_DIR}"/llm-*.log; do
            if [[ -f "$logfile" ]]; then
                local name=$(basename "$logfile" .log)
                echo -e "${YELLOW}=== ${name} (last 20 lines) ===${NC}"
                tail -n 20 "$logfile" 2>/dev/null || echo "Unable to read log"
                echo ""
            fi
        done
    else
        local log_file="${LOG_DIR}/llm-${model}.log"
        if [[ -f "$log_file" ]]; then
            if [[ "$follow" == true ]]; then
                echo -e "${BLUE}Following logs for ${model} (Ctrl+C to exit):${NC}"
                tail -f "$log_file"
            else
                echo -e "${BLUE}Last 50 lines of ${model} logs:${NC}"
                tail -n 50 "$log_file"
            fi
        else
            echo -e "${RED}Log file not found: ${log_file}${NC}"
        fi
    fi
}

enable_model() {
    local model=$1
    local service="${MODELS[$model]}"
    
    if [[ -z "$service" ]]; then
        echo -e "${RED}Error: Unknown model '${model}'${NC}"
        exit 1
    fi
    
    systemctl --user enable "$service"
    echo -e "${GREEN}Enabled ${model} to start at boot${NC}"
}

disable_model() {
    local model=$1
    local service="${MODELS[$model]}"
    
    if [[ -z "$service" ]]; then
        echo -e "${RED}Error: Unknown model '${model}'${NC}"
        exit 1
    fi
    
    systemctl --user disable "$service"
    echo -e "${GREEN}Disabled ${model} from starting at boot${NC}"
}

reload_systemd() {
    check_systemd
    systemctl --user daemon-reload
    echo -e "${GREEN}Systemd daemon reloaded${NC}"
}

# Main execution
main() {
    if [[ $# -eq 0 ]]; then
        show_usage
        exit 1
    fi
    
    local command="$1"
    shift
    local model=""
    local extra_args=()
    
    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -f)
                extra_args+=("-f")
                ;;
            *)
                if [[ -z "$model" ]]; then
                    model="$1"
                else
                    extra_args+=("$1")
                fi
                ;;
        esac
        shift
    done
    
    case "$command" in
        start)
            if [[ -z "$model" ]]; then
                echo -e "${RED}Error: No model specified${NC}"
                show_usage
                exit 1
            fi
            start_model "$model"
            ;;
        stop)
            if [[ -z "$model" ]]; then
                echo -e "${RED}Error: No model specified${NC}"
                show_usage
                exit 1
            fi
            stop_model "$model"
            ;;
        stop-all)
            stop_all_models
            ;;
        restart)
            if [[ -z "$model" ]]; then
                echo -e "${RED}Error: No model specified${NC}"
                show_usage
                exit 1
            fi
            restart_model "$model"
            ;;
        switch)
            if [[ -z "$model" ]]; then
                echo -e "${RED}Error: No model specified${NC}"
                show_usage
                exit 1
            fi
            switch_model "$model"
            ;;
        status)
            show_status "$model"
            ;;
        list)
            show_list
            ;;
        ps)
            show_ps
            ;;
        logs)
            show_logs "$model" "${extra_args[@]}"
            ;;
        setup)
            setup_services
            ;;
        enable)
            if [[ -z "$model" ]]; then
                echo -e "${RED}Error: No model specified${NC}"
                show_usage
                exit 1
            fi
            enable_model "$model"
            ;;
        disable)
            if [[ -z "$model" ]]; then
                echo -e "${RED}Error: No model specified${NC}"
                show_usage
                exit 1
            fi
            disable_model "$model"
            ;;
        reload)
            reload_systemd
            ;;
        help|--help|-h)
            show_usage
            ;;
        *)
            echo -e "${RED}Error: Unknown command '${command}'${NC}"
            echo ""
            show_usage
            exit 1
            ;;
    esac
}

main "$@"
