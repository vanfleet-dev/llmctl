#!/usr/bin/env bash
# llmctl - LLM Model Controller
# Manages llama.cpp systemd services for local LLM inference
# Usage: llmctl [command] [model] [options]
# 
# CRITICAL: Only ONE model can run at a time on RTX 3090 (24GB VRAM)
# This tool enforces mutual exclusivity - starting one model stops all others

set -euo pipefail

# Configuration
SERVICE_DIR="$HOME/.config/systemd/user"
LOG_DIR="$HOME/.local/log"
BIN_DIR="/home/nervkil/apps/llama.cpp/build/bin"
HOME_DIR="/home/nervkil"
APPS_DIR="/home/nervkil/apps"
MODELS_DIR="/mnt/llm"  # Base directory for all LLM models
TEMPLATES_DIR="/home/nervkil/apps/templates"  # Chat template files

# Create log directory if it doesn't exist
mkdir -p "$LOG_DIR"
mkdir -p "$SERVICE_DIR"

# Model configuration
# NOTE: Only ONE model can run at a time - enforced by start_model()
declare -A MODELS=(
    ["glm"]="llm-glm.service"
    ["qwen"]="llm-qwen.service"
    ["glm-opus"]="llm-glm-opus.service"
    ["qwen3.5-27b-opus"]="llm-qwen3.5-27b-opus.service"
)

declare -A MODEL_PORTS=(
    ["glm"]="8003"
    ["qwen"]="8001"
    ["glm-opus"]="8004"
    ["qwen3.5-27b-opus"]="8005"
)

# Color codes
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# Helper functions
show_usage() {
    echo "Usage: llmctl [COMMAND] [MODEL] [OPTIONS]"
    echo ""
    echo "Commands:"
    echo "  start <model>      Start a model server (stops all others first)"
    echo "  stop <model>       Stop a model server"
    echo "  stop-all           Stop ALL model servers"
    echo "  restart <model>    Restart a model server"
    echo "  status [model]     Show status of service(s)"
    echo "  list               List all configured models"
    echo "  ps                 Show running llama-server processes"
    echo "  logs [model]       Show logs (use -f to follow)"
    echo "  setup              Create/update systemd services"
    echo "  enable <model>     Enable at boot"
    echo "  disable <model>    Disable at boot"
    echo "  reload             Reload systemd daemon"
    echo "  switch <model>     Stop current, start new model"
    echo ""
    echo "Models:"
    echo "  glm                 - GLM-4.7-Flash (port 8003, 200K context, tool calling)"
    echo "  qwen                - Qwen3.5-397B (port 8001, 256K context, tool calling)"
    echo "  glm-opus            - GLM-4.7-Flash-Claude-Opus-4.5 (port 8004, 200K context, tool calling)"
    echo "  qwen3.5-27b-opus    - Qwen3.5-27B-Claude-4.6-Opus-Distill (port 8005, 262K context, tool calling)"
    echo ""
    echo "IMPORTANT: Only ONE model can run at a time on RTX 3090!"
    echo "   Starting a model automatically stops all others."
    echo ""
    echo "Examples:"
    echo "  llmctl start glm          # Start GLM (stops Qwen if running)"
    echo "  llmctl switch qwen        # Stop current, start Qwen"
    echo "  llmctl status              # Show all services"
    echo "  llmctl logs glm -f         # Follow GLM logs"
    echo "  llmctl stop-all            # Emergency stop all models"
}

check_systemd() {
    if ! command -v systemctl &> /dev/null; then
        echo -e "${RED}Error: systemctl not found${NC}"
        exit 1
    fi
}

check_root() {
    if [[ $EUID -eq 0 ]]; then
        echo -e "${RED}Error: Do not run as root${NC}"
        exit 1
    fi
}

# CRITICAL: Stop all other models before starting a new one
# This prevents OOM (Out of Memory) crashes
stop_all_others() {
    local model_to_keep="${1:-}"
    
    echo -e "${BLUE}Checking for other running models...${NC}"
    
    for model_key in "${!MODELS[@]}"; do
        if [[ "$model_key" != "$model_to_keep" ]]; then
            local service="${MODELS[$model_key]}"
            if systemctl --user is-active --quiet "$service" 2>/dev/null; then
                echo -e "${YELLOW}Stopping $model_key to free VRAM...${NC}"
                systemctl --user stop "$service" 2>/dev/null || true
                sleep 2
            fi
        fi
    done
    
    # Double-check with pkill as fallback
    local port_to_keep=""
    if [[ -n "$model_to_keep" ]]; then
        port_to_keep="${MODEL_PORTS[$model_to_keep]}"
    fi
    
    # Kill any llama-server processes except the one we're about to start
    for pid in $(pgrep -f "llama-server" 2>/dev/null || true); do
        if [[ -n "$pid" ]]; then
            local cmdline=$(cat /proc/$pid/cmdline 2>/dev/null | tr '\0' ' ' || true)
            if [[ -n "$port_to_keep" && ! "$cmdline" =~ "port $port_to_keep" ]]; then
                echo -e "${YELLOW}Killing orphaned llama-server process $pid${NC}"
                kill -9 "$pid" 2>/dev/null || true
            fi
        fi
    done
    
    sleep 2
    
    # Verify VRAM is freed
    local vram_free=$(nvidia-smi --query-gpu=memory.free --format=csv,noheader,nounits 2>/dev/null | head -1 | tr -d ' ' || echo "0")
    echo -e "${GREEN}VRAM freed: ${vram_free} MiB available${NC}"
}

