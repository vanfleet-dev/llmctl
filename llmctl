setup_services() {
    check_systemd
    check_root
    
    echo -e "${BLUE}=== LLM Controller - Service Setup ===${NC}"
    echo ""
    echo -e "${YELLOW}WARNING: This will overwrite existing service files${NC}"
    echo -e "${YELLOW}with corrected versions including all required parameters${NC}"
    echo ""
    
    create_glm_service
    create_qwen_service
    create_glm_opus_service
    create_qwen3.5_27b_opus_service
    
    echo ""
    echo -e "${BLUE}Reloading systemd daemon...${NC}"
    systemctl --user daemon-reload
    
    echo ""
    echo -e "${GREEN}=== Setup Complete ===${NC}"
    echo "Services updated for: glm, qwen, glm-opus, qwen3.5-27b-opus"
    echo ""
    echo "To start a model (only one at a time!):"
    echo "  llmctl start glm                # Start GLM-4.7-Flash"
    echo "  llmctl start qwen               # Start Qwen3.5-397B"
    echo "  llmctl start glm-opus           # Start GLM-4.7-Flash-Claude-Opus-4.5"
    echo "  llmctl start qwen3.5-27b-opus   # Start Qwen3.5-27B-Claude-4.6-Opus-Distill"
    echo ""
    echo "To switch between models:"
    echo "  llmctl switch qwen              # Automatically stops current, starts Qwen"
    echo "  llmctl switch glm-opus          # Automatically stops current, starts GLM-Opus"
    echo "  llmctl switch qwen3.5-27b-opus  # Automatically stops current, starts Qwen3.5-27B-Opus"
}

start_model() {
    local model=$1
    local service="${MODELS[$model]}"
    local port="${MODEL_PORTS[$model]}"
    
    if [[ -z "$service" ]]; then
        echo -e "${RED}Error: Unknown model '${model}'${NC}"
        echo ""
        echo "Available models:"
        for key in "${!MODELS[@]}"; do
            echo "  $key"
        done
        exit 1
    fi
    
    # CRITICAL: Stop all other models first to prevent OOM
    stop_all_others "$model"
    
    # CRITICAL: Manage systemd enable/disable state to ensure only one model
    # persists after reboot. Disable all other models from systemd auto-start,
    # then enable only the model we're starting.
    echo -e "${BLUE}Updating systemd auto-start configuration...${NC}"
    for other_model in "${!MODELS[@]}"; do
        if [[ "$other_model" != "$model" ]]; then
            local other_service="${MODELS[$other_model]}"
            # Suppress error if already disabled or service doesn't exist
            systemctl --user disable "$other_service" 2>/dev/null || true
        fi
    done
    
    # Enable only this model for auto-start (suppress error if already enabled)
    systemctl --user enable "$service" 2>/dev/null || true
    
    echo -e "${GREEN}Starting ${model} service on port ${port}...${NC}"
    systemctl --user start "$service"
    
    sleep 3
    
    if systemctl --user is-active --quiet "$service"; then
        echo -e "${GREEN}✓ ${model} is now running on port ${port}${NC}"
        systemctl --user --no-pager status "$service" | head -8
    else
        echo -e "${RED}✗ Failed to start ${model}${NC}"
        echo "Check logs: llmctl logs ${model}"
        exit 1
    fi
}

stop_model() {
    local model=$1
    local service="${MODELS[$model]}"
    
    if [[ -z "$service" ]]; then
        echo -e "${RED}Error: Unknown model '${model}'${NC}"
        exit 1
    fi
    
    systemctl --user stop "$service" 2>/dev/null || true
    
    # Also kill by port as fallback
    local port="${MODEL_PORTS[$model]}"
    lsof -ti:"$port" | xargs kill -9 2>/dev/null || true
    
    echo -e "${GREEN}Stopped ${model} service${NC}"
}

stop_all_models() {
    echo -e "${YELLOW}Stopping ALL LLM services...${NC}"
    
    for model in "${!MODELS[@]}"; do
        local service="${MODELS[$model]}"
        if systemctl --user is-active --quiet "$service" 2>/dev/null; then
            echo -e "${YELLOW}Stopping ${model}...${NC}"
            systemctl --user stop "$service" 2>/dev/null || true
        fi
    done
    
    # Nuclear option: kill all llama-server processes
    pkill -9 -f "llama-server" 2>/dev/null || true
    
    sleep 2
    echo -e "${GREEN}All LLM services stopped${NC}"
    
    # Show freed VRAM
    local vram_free=$(nvidia-smi --query-gpu=memory.free --format=csv,noheader,nounits 2>/dev/null | head -1 | tr -d ' ' || echo "0")
    echo -e "${GREEN}VRAM freed: ${vram_free} MiB available${NC}"
}

restart_model() {
    local model=$1
    local service="${MODELS[$model]}"
    
    if [[ -z "$service" ]]; then
        echo -e "${RED}Error: Unknown model '${model}'${NC}"
        exit 1
    fi
    
    # Also stop others to be safe
    stop_all_others "$model"
    
    systemctl --user restart "$service"
    echo -e "${GREEN}Restarted ${model} service${NC}"
    sleep 3
    systemctl --user --no-pager status "$service" | head -10
}

switch_model() {
    local model=$1
    
    if [[ -z "$model" ]]; then
        echo -e "${RED}Error: No model specified${NC}"
        show_usage
        exit 1
    fi
    
    echo -e "${BLUE}Switching to ${model}...${NC}"
    stop_all_others "$model"
    start_model "$model"
}

show_status() {
    local model=${1:-}
    
    if [[ -z "$model" ]]; then
        echo -e "${BLUE}=== All LLM Services ===${NC}"
        systemctl --user list-units --no-pager | grep -E "llm-|UNIT" | head -20
        echo ""
        echo -e "${BLUE}=== GPU Status ===${NC}"
        nvidia-smi | grep -E "(GPU|llama|MiB|Processes)" -A8
    else
        local service="${MODELS[$model]}"
        if [[ -n "$service" ]]; then
            systemctl --user --no-pager status "$service"
        else
            echo -e "${RED}Unknown model: ${model}${NC}"
            exit 1
        fi
    fi
}

